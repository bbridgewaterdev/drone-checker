rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own document and subcollections, but
    // entitlement/billing fields are server-only (set by Cloud Functions via
    // the Admin SDK, which bypasses these rules). Without this restriction a
    // signed-in user could grant themselves Pro with a direct Firestore write
    // (e.g. `update({isPro: true})` from devtools) — these fields must never
    // be touched by a client-supplied create/update.
    match /users/{userId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(
          ['isPro','stripeCustomerId','stripeSubscriptionId','proActivatedAt','proRevokedAt','lastRenewalAt']);

      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['isPro','stripeCustomerId','stripeSubscriptionId','proActivatedAt','proRevokedAt','lastRenewalAt']);

      // Cover any subcollections under users/{userId}
      match /{subcollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // In-app feedback: write-only inbox, open to signed-out free users too (not
    // gated behind auth like /users/{userId}), so anyone can send a bug report or
    // idea. Clients can never read, update or delete — only create a new doc, and
    // only one shaped like a feedback entry with a server-set timestamp (so the
    // create time can't be spoofed). If a uid is attached it must be the caller's
    // own, mirroring the ownership check used on /users/{userId} above.
    match /feedback/{feedbackId} {
      allow create: if request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000
        && request.resource.data.category in ['bug', 'idea', 'other']
        && request.resource.data.createdAt == request.time
        && (!('uid' in request.resource.data)
          || request.resource.data.uid == null
          || (request.auth != null && request.resource.data.uid == request.auth.uid));
      allow read, update, delete: if false;
    }

    // Deny everything else explicitly
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
